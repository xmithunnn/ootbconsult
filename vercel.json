{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/capabilities",     "destination": "/index.html" },
    { "source": "/packages",         "destination": "/index.html" },
    { "source": "/genesis",          "destination": "/index.html" },
    { "source": "/careers",          "destination": "/index.html" },
    { "source": "/contact",          "destination": "/index.html" },
    { "source": "/mrpuffscanada",    "destination": "/index.html" },
    { "source": "/venturex-canada",  "destination": "/index.html" },
    { "source": "/911nursesgta",     "destination": "/index.html" },
    { "source": "/stonestudios",     "destination": "/index.html" },
    { "source": "/maritime-asthma",  "destination": "/index.html" },
    { "source": "/calypso-hut",      "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" }
      ]
    }
  ]
}
